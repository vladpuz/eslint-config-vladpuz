{
  "name": "eslint-config-vladpuz",
  "version": "4.1.1",
  "description": "My ESLint config",
  "keywords": [
    "vladpuz",
    "eslint",
    "eslintconfig"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vladpuz/eslint-config-vladpuz.git"
  },
  "license": "MIT",
  "author": "Vladislav Puzyrev",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.build.json",
    "check": "npm run typecheck && npm run lint && npm run format",
    "format": "prettier --check .",
    "lint": "eslint .",
    "prepack": "npm run build && npm run check && npm run test",
    "prepare": "husky",
    "test": "node --test",
    "test-update-snapshots": "node --test --test-update-snapshots",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-plugin-import-lite": "^0.6.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^65.0.1",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.61.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/node-ts": "^23.6.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "prettier-config-vladpuz": "^3.0.0",
    "rimraf": "^6.1.3"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "typescript": "^6.0.0"
  }
}
